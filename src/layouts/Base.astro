---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Data Behind the Scenes — the magazine.' } = Astro.props;

// Self-hosted webfonts live in /public/fonts/, so their URLs need the same
// base-path prefix as everything else once this is deployed under a GitHub
// Pages project subpath. Built here as plain CSS text (not a <style> block
// with define:vars) because CSS custom properties are not honored inside
// @font-face declarations in any browser.
const fontsBase = import.meta.env.BASE_URL.replace(/\/$/, '') + '/fonts/';
const fontFaceCSS = `
@font-face {
  font-family: 'Fraunces';
  src: url('${fontsBase}fraunces-latin-600-normal.woff2') format('woff2');
  font-weight: 600;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Instrument Serif';
  src: url('${fontsBase}InstrumentSerif-Italic.ttf') format('truetype');
  font-weight: 400;
  font-style: italic;
  font-display: swap;
}
@font-face {
  font-family: 'IBM Plex Mono';
  src: url('${fontsBase}IBMPlexMono-Regular.ttf') format('truetype');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'IBM Plex Mono';
  src: url('${fontsBase}IBMPlexMono-Bold.ttf') format('truetype');
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Data Behind the Scenes</title>
    <style set:html={fontFaceCSS}></style>
  </head>
  <body>
    <slot name="masthead" />
    <Nav />
    <main class="wrap">
      <slot />
    </main>
    <Footer />
  </body>
</html>
