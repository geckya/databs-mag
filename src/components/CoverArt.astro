---
// Generative "cover" for pieces that don't have real photography/illustration yet.
// Deterministic from `seed` (use the entry slug) so a given piece always gets the
// same pattern across rebuilds — swap this out for a real <img> once art direction
// (real photos, commissioned illustration, whatever the group lands on) exists.
interface Props {
  seed: string;
  aspect?: string;
}
const { seed, aspect = '16 / 10' } = Astro.props;

function hashStr(s: string) {
  let h = 0;
  for (let i = 0; i < s.length; i++) {
    h = (h << 5) - h + s.charCodeAt(i);
    h |= 0;
  }
  return Math.abs(h);
}

function mulberry32(a: number) {
  return function () {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const seedNum = hashStr(seed);
const rand = mulberry32(seedNum);
const palette = ['#22594a', '#3f9c82', '#1a2238', '#9fc9bb'];
const bgTone = '#faf8f4';
const variant = ['bars', 'dots', 'waves'][seedNum % 3];

const bars = Array.from({ length: 20 }, (_, i) => ({
  x: (i * 100) / 20,
  h: 8 + Math.floor(rand() * 78),
  color: palette[Math.floor(rand() * palette.length)],
}));

const dots = Array.from({ length: 46 }, () => ({
  cx: rand() * 100,
  cy: rand() * 100,
  r: 0.8 + rand() * 2.6,
  color: palette[Math.floor(rand() * palette.length)],
}));

const waves = Array.from({ length: 4 }, (_, i) => {
  const amp = 6 + rand() * 14;
  const freq = 1 + rand() * 2.5;
  const phase = rand() * 6.28;
  const yBase = 20 + i * 20;
  const color = palette[Math.floor(rand() * palette.length)];
  let d = `M 0 ${yBase}`;
  for (let x = 0; x <= 100; x += 4) {
    const y = yBase + Math.sin(x * 0.06 * freq + phase) * amp;
    d += ` L ${x} ${y.toFixed(1)}`;
  }
  return { d, color };
});
---

<div class="cover-art" style={`aspect-ratio: ${aspect};`}>
  <svg viewBox="0 0 100 100" preserveAspectRatio="none" role="presentation" aria-hidden="true">
    <rect x="0" y="0" width="100" height="100" fill={bgTone} />
    {
      variant === 'bars' &&
        bars.map((b) => (
          <rect x={b.x} y={100 - b.h} width={100 / 20 - 1} height={b.h} fill={b.color} />
        ))
    }
    {
      variant === 'dots' &&
        dots.map((d) => <circle cx={d.cx} cy={d.cy} r={d.r} fill={d.color} />)
    }
    {
      variant === 'waves' &&
        waves.map((w) => (
          <path d={w.d} fill="none" stroke={w.color} stroke-width="2.2" />
        ))
    }
  </svg>
</div>

<style>
  .cover-art {
    width: 100%;
    display: block;
    background: #faf8f4;
    line-height: 0;
  }

  .cover-art svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
