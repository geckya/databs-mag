---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';

const cfps = (await getCollection('calls-for-proposals')).sort(
  (a, b) => a.data.deadline.valueOf() - b.data.deadline.valueOf()
);

const withIssue = await Promise.all(
  cfps.map(async (cfp) => ({
    cfp,
    issue: await getEntry(cfp.data.issue),
    rendered: await render(cfp),
  }))
);

const open = withIssue.filter((c) => c.cfp.data.status === 'open');
const closed = withIssue.filter((c) => c.cfp.data.status === 'closed');
---

<Base title="Call for Proposals" description="Pitch us something for an upcoming issue.">
  <h1>Call for Proposals</h1>
  <p class="dek">
    Invitations to contribute to a future issue. Pitch through our GitHub issue template — see
    the guidelines link on each open call below.
  </p>

  {
    open.length > 0 ? (
      <section class="section">
        <h2>Open</h2>
        {open.map(({ cfp, issue, rendered }) => (
          <article class="card">
            <p class="meta">
              For Issue {issue?.data.number} · Deadline {cfp.data.deadline.toDateString()}
            </p>
            <h3>{cfp.data.theme}</h3>
            <div class="prose">
              <rendered.Content />
            </div>
            {cfp.data.guidelinesUrl && (
              <p>
                <a href={cfp.data.guidelinesUrl}>Submission guidelines →</a>
              </p>
            )}
          </article>
        ))}
      </section>
    ) : (
      <p class="meta">No open calls right now — check back next quarter.</p>
    )
  }

  {
    closed.length > 0 && (
      <section class="section">
        <h2>Past calls</h2>
        <div class="card-grid">
          {closed.map(({ cfp, issue }) => (
            <div class="card">
              <p class="meta">Issue {issue?.data.number}</p>
              <h3>{cfp.data.theme}</h3>
            </div>
          ))}
        </div>
      </section>
    )
  }
</Base>
